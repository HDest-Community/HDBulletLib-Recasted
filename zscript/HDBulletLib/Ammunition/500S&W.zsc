const ENC_50SW = 1.2;
const ENC_50SW_LOADED = 0.9;

// [Ace] Regular.
class HDB_500SW : HDBulletActor
{
	Default
	{
		Pushfactor 0.3;
		Mass 230;
		Speed 800;
		Accuracy 240;
		Stamina 1270;
		WoundHealth 30;
		HDBulletActor.Hardness 3;
	}
}

