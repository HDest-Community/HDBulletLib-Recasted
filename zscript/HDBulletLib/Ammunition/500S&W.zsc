class HDLoose500Light : HDLoose9mm
{
	Default
	{
		bouncefactor 0.5;
	}
	
	States
	{
		spawn:
			SWCS A 2 NoDelay A_SetRoll(roll + 45, SPF_INTERPOLATE);
			Loop;
		death:
			SWCS # 1{
				actor a=spawn("HD500SWLightAmmo",self.pos,ALLOW_REPLACE);
				a.roll=self.roll;a.vel=self.vel;
			}stop;
	}
}

class HDLoose500Heavy : HDLoose9mm
{
	Default
	{
		bouncefactor 0.5;
	}
	
	States
	{
		spawn:
			SWCS A 2 NoDelay A_SetRoll(roll + 45, SPF_INTERPOLATE);
			Loop;
