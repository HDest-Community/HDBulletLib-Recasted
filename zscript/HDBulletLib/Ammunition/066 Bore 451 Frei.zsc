		height 16;radius 8;
		tag "$TAG_420CASING";
		hdpickup.bulk ENC_420_LOADED;
		xscale 0.7;yscale 0.8;
		inventory.pickupmessage "$PICKUP_420CASING";
		inventory.icon "420SA0";
	}
	states{
	spawn:
		420S A -1;
		stop;
	}
}

