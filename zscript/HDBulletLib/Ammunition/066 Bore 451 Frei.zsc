class HDSpent069Bore:HDUPK{
	default{
		bouncesound "misc/casing2";
		xscale 0.3;
		yscale 0.4;
		+missile
		+hdupk.multipickup
		height 2;radius 2;
		bouncetype "doom";
		hdupk.pickuptype "HD069Brass";
		hdupk.pickupmessage "$PICKUP_069CASING";

		bouncefactor 0.4;
		maxstepheight 0.6;
	}
	states{
	spawn:
		42BR A 2 nodelay{
			A_SetRoll(roll+45,SPF_INTERPOLATE);
			if(bseesdaggers)angle-=45;else angle+=45;
			if(pos.z-floorz<2&&abs(vel.z)<2.)setstatelabel("death");
		}wait;
	death:
		42BR A -1{
			if(hdmath.deathmatchclutter())A_SetTics(140);
			bmissile=false;
			vel.xy+=(pos.xy-lastpos.xy)*max(abs(vel.z),abs(lastpos.z-pos.z),1.);
			if(vel.xy==(0,0)){
				double aaa=angle-90;
				vel.x+=cos(aaa);
				vel.y+=sin(aaa);
			}else{
				A_FaceMovementDirection();
				angle+=90;
			}
			let gdb=getdefaultbytype(pickuptype);
			A_SetSize(gdb.radius,gdb.height);
			return;
		}stop;
	}
}

