class HDSpent420b:HDUPK{
	default{
		+missile
		+hdupk.multipickup
		height 4;radius 2;
		bouncetype "doom";
		hdupk.pickuptype "HD420Brass";
		hdupk.pickupmessage "$PICKUP_420CASING";

		bouncefactor 0.4;
		bouncesound "misc/casing3";scale 0.6;
		maxstepheight 0.6;
	}
	override void A_HDUPKGive()
	{
		if(hdb_nocasingpickup)Super.A_HDUPKGive();
	}
	states{
	spawn:
		420S A 2 nodelay{
			if(bseesdaggers)angle-=45;else angle+=45;
			if(pos.z-floorz<2&&abs(vel.z)<2.)setstatelabel("death");
		}wait;
	death:
		420S # -1{
			if(hdmath.deathmatchclutter())A_SetTics(140);
			bmissile=false;
			let gdb=getdefaultbytype(pickuptype);
			A_SetSize(gdb.radius,gdb.height);
			return;
		}stop;
	}
}

class HDSpent420:HDDebris{
	default{
		bouncesound "misc/casing3";scale 0.6;
	}
	states{
	spawn:
		420S A 2 nodelay A_SetRoll(roll+45,SPF_INTERPOLATE);
		loop;
	death:
		TNT1 # -1 A_SpawnItem('HDSpent420b');
		stop;
	}
}

class HD420Brass:HDAmmo{
	default{
		+inventory.ignoreskill +forcexybillboard +cannotpush
		+hdpickup.multipickup
